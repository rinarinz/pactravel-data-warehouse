  create  table "pactravel_dwh"."final"."fct_daily_total__dbt_tmp"
  
  
    as
  
  (
    

with combined as (
    select 'flight' as booking_type, departure_date as booking_date, price from "pactravel_dwh"."pactravel"."flight_bookings"
    union all
    select 'hotel' as booking_type, check_in_date as booking_date, price from "pactravel_dwh"."pactravel"."hotel_bookings"
)

select 
    booking_date as date,
    booking_type,
    count(*) as total_bookings,
    sum(price) as total_revenue,
    avg(price) as avg_ticket_price
from combined
group by 1, 2
order by 1 desc, 2
  );
  
