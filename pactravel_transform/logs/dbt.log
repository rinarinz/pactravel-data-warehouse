  create  table "pactravel_dwh"."final"."fct_order_transaction__dbt_tmp"
  
  
    as
  
  (
    

with combined as (
    select 'flight' as type, trip_id, customer_id, departure_date as date, price 
    from "pactravel_dwh"."pactravel"."flight_bookings"
    union all
    select 'hotel' as type, trip_id, customer_id, check_in_date as date, price 
    from "pactravel_dwh"."pactravel"."hotel_bookings"
)

select 
    c.trip_id,
    c.type as booking_type,
    c.customer_id,
    c.date as booking_date,
    c.price as price,
    cust.first_name || ' ' || cust.last_name as customer_name
from combined c
left join "pactravel_dwh"."pactravel"."customers" cust on c.customer_id = cust.customer_id
