  create  table "pactravel_dwh"."final"."fct_order_transaction__dbt_tmp"
  
  
    as
  
  (
    

with flight_details as (
    -- Mengambil data penerbangan dengan join ke maskapai, bandara, dan pesawat
    select 
        fb.trip_id,
        'flight' as booking_type,
        fb.customer_id,
        fb.departure_date as booking_date,
        fb.price,
        al.airline_name as provider_name,
        ap_src.city as origin,
        ap_dst.city as destination,
        ac.aircraft_name as travel_details
    from "pactravel_dwh"."pactravel"."flight_bookings" fb
    left join "pactravel_dwh"."pactravel"."airlines" al 
        on fb.airline_id = al.airline_id
    left join "pactravel_dwh"."pactravel"."airports" ap_src 
        on fb.airport_src = ap_src.airport_id
    left join "pactravel_dwh"."pactravel"."airports" ap_dst 
        on fb.airport_dst = ap_dst.airport_id
    left join "pactravel_dwh"."pactravel"."aircrafts" ac 
        on fb.aircraft_id = ac.aircraft_id
),

hotel_details as (
    -- Mengambil data hotel dengan join ke tabel hotel untuk nama dan lokasi
    select 
        hb.trip_id,
        'hotel' as booking_type,
        hb.customer_id,
        hb.check_in_date as booking_date,
        hb.price,
        h.hotel_name as provider_name,
        null as origin, -- Hotel tidak punya kota asal
        h.city as destination,
        null as travel_details -- Hotel tidak punya info kendaraan
    from "pactravel_dwh"."pactravel"."hotel_bookings" hb
    left join "pactravel_dwh"."pactravel"."hotel" h 
        on hb.hotel_id = h.hotel_id
),

combined_data as (
    select * from flight_details
    union all
    select * from hotel_details
)

-- Final select dengan join ke tabel customers untuk mendapatkan nama lengkap
select 
    cd.trip_id,
    cd.booking_type,
    cd.customer_id,
    cust.customer_first_name || ' ' || cust.customer_family_name as customer_name,
    cd.booking_date,
    cd.price,
    cd.provider_name,
    cd.origin,
    cd.destination,
    cd.travel_details
from combined_data cd
left join "pactravel_dwh"."pactravel"."customers" cust 
    on cd.customer_id = cust.customer_id
  );
  
