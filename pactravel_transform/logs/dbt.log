  create  table "pactravel_dwh"."final"."fct_order_transaction__dbt_tmp"
  
  
    as
  
  (
    

with flight_details as (
    select 
        fb.trip_id::bigint, 
        'flight' as booking_type, 
        fb.customer_id::bigint, 
        fb.airline_id::bigint,     
        fb.airport_src::bigint,    
        fb.airport_dst::bigint,    
        fb.aircraft_id::bigint,    
        cast(null as bigint) as hotel_id, -- Paksa null jadi bigint
        fb.departure_date::date as booking_date, 
        fb.price::numeric as price,
        al.airline_name as provider_name, 
        ap_src.city as origin, 
        ap_dst.city as destination, 
        ac.aircraft_name as travel_details
    from "pactravel_dwh"."pactravel"."flight_bookings" fb
    left join "pactravel_dwh"."final"."dim_airlines" al on fb.airline_id = al.airline_id
    left join "pactravel_dwh"."final"."dim_airports" ap_src = ap_src.airport_id
    left join "pactravel_dwh"."final"."dim_airports" ap_dst = ap_dst.airport_id
    left join "pactravel_dwh"."final"."dim_aircrafts" ac = ac.aircraft_id
),

hotel_details as (
    select 
        hb.trip_id::bigint, 
        'hotel' as booking_type, 
        hb.customer_id::bigint, 
        cast(null as bigint) as airline_id, 
        cast(null as bigint) as airport_src, 
        cast(null as bigint) as airport_dst, 
        cast(null as bigint) as aircraft_id, 
        hb.hotel_id::bigint,       
        hb.check_in_date::date as booking_date, 
        hb.price::numeric as price,
        h.hotel_name as provider_name, 
        cast(null as text) as origin, 
        h.city as destination, 
        cast(null as text) as travel_details
    from "pactravel_dwh"."pactravel"."hotel_bookings" hb
    left join "pactravel_dwh"."final"."dim_hotels" h on hb.hotel_id = h.hotel_id
),

combined as (
    select * from flight_details
    union all
    select * from hotel_details
)

select 
    c.*,
    cust.full_name as customer_name
from combined c
left join "pactravel_dwh"."final"."dim_customers" cust on c.customer_id = cust.customer_id
  );
  
