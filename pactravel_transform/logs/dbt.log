  create  table "pactravel_dwh"."final"."fct_order_transaction__dbt_tmp"
  
  
    as
  
  (
    

with flight_details as (
    select 
        -- Kita paksa semua ID jadi text di sini supaya UNION-nya lancar
        fb.trip_id::text as trip_id, 
        'flight' as booking_type, 
        fb.customer_id::text as customer_id, 
        fb.airline_id::text as airline_id,     
        fb.airport_src::text as airport_src,    
        fb.airport_dst::text as airport_dst,    
        fb.aircraft_id::text as aircraft_id,    
        cast(null as text) as hotel_id, 
        fb.departure_date::date as booking_date, 
        fb.price::numeric as price,
        al.airline_name::text as provider_name, 
        ap_src.city::text as origin, 
        ap_dst.city::text as destination, 
        ac.aircraft_name::text as travel_details
    from "pactravel_dwh"."pactravel"."flight_bookings" fb
    left join "pactravel_dwh"."final"."dim_airlines" al on fb.airline_id = al.airline_id
    left join "pactravel_dwh"."final"."dim_airports" ap_src on fb.airport_src = ap_src.airport_id
    left join "pactravel_dwh"."final"."dim_airports" ap_dst on fb.airport_dst = ap_dst.airport_id
    left join "pactravel_dwh"."final"."dim_aircrafts" ac on fb.aircraft_id = ac.aircraft_id
),

hotel_details as (
    select 
        hb.trip_id::text as trip_id, 
        'hotel' as booking_type, 
        hb.customer_id::text as customer_id, 
        cast(null as text) as airline_id, 
        cast(null as text) as airport_src, 
        cast(null as text) as airport_dst, 
        cast(null as text) as aircraft_id, 
        hb.hotel_id::text as hotel_id,       
        hb.check_in_date::date as booking_date, 
        hb.price::numeric as price,
        h.hotel_name::text as provider_name, 
        cast(null as text) as origin, 
        h.city::text as destination, 
        cast(null as text) as travel_details
    from "pactravel_dwh"."pactravel"."hotel_bookings" hb
    left join "pactravel_dwh"."final"."dim_hotels" h on hb.hotel_id = h.hotel_id
),

combined as (
    select * from flight_details
    union all
    select * from hotel_details
)

-- Di select final, kita kembalikan ID menjadi angka (bigint) agar bagus di ERD
select 
    c.trip_id::bigint,
    c.booking_type,
    c.customer_id::bigint,
    cust.full_name as customer_name,
    c.airline_id::bigint,
    c.hotel_id::bigint,
    c.airport_src::bigint,
    c.airport_dst::bigint,
    c.aircraft_id::bigint,
    c.booking_date,
    c.price,
    c.provider_name,
    c.origin,
    c.destination,
    c.travel_details
from combined c
left join "pactravel_dwh"."final"."dim_customers" cust on c.customer_id = cust.customer_id
  );
  
