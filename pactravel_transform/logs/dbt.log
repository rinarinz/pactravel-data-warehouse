  create  table "pactravel_dwh"."final"."fct_daily_total__dbt_tmp"
  
  
    as
  
  (
    

with all_bookings as (
    -- Mengambil data penerbangan menggunakan departure_date
    select departure_date as booking_date, trip_id, price 
    from "pactravel_dwh"."pactravel"."flight_bookings"
    union all
    -- Mengambil data hotel menggunakan check_in_date
    select check_in_date as booking_date, trip_id, price 
    from "pactravel_dwh"."pactravel"."hotel_bookings"
)

select 
    booking_date::date as date,
    count(trip_id) as total_bookings,
    sum(price) as total_revenue
from all_bookings
group by 1
order by 1
  );
  
