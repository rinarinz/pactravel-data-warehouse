  create  table "pactravel_dwh"."final"."fct_order_transaction__dbt_tmp"
  
  
    as
  
  (
    

with flight_details as (
    select 
        fb.trip_id, 
        'flight' as booking_type, 
        fb.customer_id, 
        fb.airline_id,     
        fb.airport_src,    
        fb.airport_dst,    
        fb.aircraft_id,    
        cast(null as bigint) as hotel_id, -- Kita paksa null jadi bigint agar sejajar dengan ID Hotel
        fb.departure_date as booking_date, 
        fb.price,
        al.airline_name as provider_name, 
        ap_src.city as origin, 
        ap_dst.city as destination, 
        ac.aircraft_name as travel_details
    from "pactravel_dwh"."pactravel"."flight_bookings" fb
    left join "pactravel_dwh"."final"."dim_airlines" al on fb.airline_id = al.airline_id
    left join "pactravel_dwh"."final"."dim_airports" ap_src on fb.airport_src = ap_src.airport_id
    left join "pactravel_dwh"."final"."dim_airports" ap_dst on fb.airport_dst = ap_dst.airport_id
    left join "pactravel_dwh"."final"."dim_aircrafts" ac on fb.aircraft_id = ac.aircraft_id
),

hotel_details as (
    select 
        hb.trip_id, 
        'hotel' as booking_type, 
        hb.customer_id, 
        cast(null as bigint) as airline_id, -- Dipaksa jadi bigint
        cast(null as bigint) as airport_src, 
        cast(null as bigint) as airport_dst, 
        cast(null as bigint) as aircraft_id, 
        hb.hotel_id,       
        hb.check_in_date as booking_date, 
        hb.price,
        h.hotel_name as provider_name, 
        cast(null as text) as origin,        -- Dipaksa jadi text
        h.city as destination, 
        cast(null as text) as travel_details -- Dipaksa jadi text
    from "pactravel_dwh"."pactravel"."hotel_bookings" hb
    left join "pactravel_dwh"."final"."dim_hotels" h on hb.hotel_id = h.hotel_id
),

combined as (
    select * from flight_details
    union all
    select * from hotel_details
)

select 
    c.trip_id,
    c.booking_type,
    c.customer_id,
    cust.full_name as customer_name,
    c.airline_id,
    c.hotel_id,
    c.airport_src,
    c.airport_dst,
    c.aircraft_id,
    c.booking_date,
    c.price,
    c.provider_name,
    c.origin,
    c.destination,
    c.travel_details
from combined c
left join "pactravel_dwh"."final"."dim_customers" cust on c.customer_id = cust.customer_id
  );
  
